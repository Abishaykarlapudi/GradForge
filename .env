PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/gradforge
JWT_SECRET=gradforge_secret_jwt_key_123
NODE_ENV=development

# AI Configuration (Options: "gemini" | "openai")
AI_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

# Cloudinary Integration (Local storage fallback is used if blank)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Mail Setup (Nodemailer Console logger is used if blank)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM="GradForge" <noreply@gradforge.com>
